# === 必填 ===
# 管理员账号
AUTH_USERNAME=admin
# 管理员密码
AUTH_PASSWORD=your-password-here
# JWT 签名密钥（请使用随机字符串）
JWT_SECRET=your-jwt-secret-here

# GitHub Token (需要有 repo 权限)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
# GitHub 仓库名, 格式: username/repo
GITHUB_REPO=username/butterfly-link-check

# === 可选 ===
# 文件在仓库中的路径（默认值即可）
FILE_1_PATH=link.yml
FILE_2_PATH=manual_check.json

# Cloudflare Worker 地址（用于辅助检测，不填则跳过该阶段）
CF_WORKER_URL=
